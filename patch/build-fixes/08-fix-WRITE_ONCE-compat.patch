From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: kernel-builder <builder@github.com>
Date: Mon, 9 Jun 2026 00:00:00 +0000
Subject: [PATCH] fix: replace WRITE_ONCE with direct assignment for old Clang

Old Clang does not support WRITE_ONCE macro expansion for this pattern.

Signed-off-by: kernel-builder <builder@github.com>
---
 lib/fault-inject.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

@@ -111,7 +111,7 @@
 		unsigned int fail_nth = READ_ONCE(current->fail_nth);
 
 		if (fail_nth) {
-			if (!WRITE_ONCE(current->fail_nth, fail_nth - 1))
+			if (!(current->fail_nth = fail_nth - 1))
 				goto fail;
 
 			return false;
