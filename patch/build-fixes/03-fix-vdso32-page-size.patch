From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: kernel-builder <builder@github.com>
Date: Mon, 9 Jun 2026 00:00:00 +0000
Subject: [PATCH] fix: remove -z page-size flags from VDSO32 for old LLD

Old ld.lld does not support -z common-page-size and -z max-page-size.

Signed-off-by: kernel-builder <builder@github.com>
---
 arch/arm64/kernel/vdso32/Makefile | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

@@ -107,7 +107,7 @@
 
 # From arm vDSO Makefile
 VDSO_LDFLAGS += -Bsymbolic --no-undefined -soname=linux-vdso.so.1
-VDSO_LDFLAGS += -z max-page-size=4096 -z common-page-size=4096
+VDSO_LDFLAGS +=  
 VDSO_LDFLAGS += -nostdlib -shared --hash-style=sysv --build-id
 
 
