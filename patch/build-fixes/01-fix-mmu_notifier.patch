From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: kernel-builder <builder@github.com>
Date: Mon, 9 Jun 2026 00:00:00 +0000
Subject: [PATCH] fix: mmu_notifier compatibility for kernel 4.19

- Change enum mmu_notifier_event to unsigned long (enum not defined in 4.19)
- Define MMU_NOTIFY_UNMAP and MMU_NOTIFY_CLEAR (missing from 4.19)

Signed-off-by: kernel-builder <builder@github.com>
---
 include/linux/mmu_notifier.h | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

@@ -1,6 +1,8 @@
 /* SPDX-License-Identifier: GPL-2.0 */
 #ifndef _LINUX_MMU_NOTIFIER_H
 #define _LINUX_MMU_NOTIFIER_H
+#define MMU_NOTIFY_UNMAP 0
+#define MMU_NOTIFY_CLEAR 1
 
 #include <linux/types.h>
 #include <linux/list.h>
@@ -343,7 +345,7 @@
 
 
 static inline void mmu_notifier_range_init(struct mmu_notifier_range *range,
-					   enum mmu_notifier_event event,
+					   unsigned long event,
 					   unsigned flags,
 					   struct vm_area_struct *vma,
 					   struct mm_struct *mm,
