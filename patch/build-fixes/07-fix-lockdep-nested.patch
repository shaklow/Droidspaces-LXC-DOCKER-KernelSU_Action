From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: kernel-builder <builder@github.com>
Date: Mon, 9 Jun 2026 00:00:00 +0000
Subject: [PATCH] fix: remove nested parameter from __lock_release for 4.19

__lock_release in kernel 4.19 does not have the nested parameter.

Signed-off-by: kernel-builder <builder@github.com>
---
 kernel/locking/lockdep.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

@@ -4005,7 +4005,7 @@
 	check_flags(flags);
 	current->lockdep_recursion = 1;
 	trace_lock_release(lock, ip);
-	if (__lock_release(lock, nested, ip))
+	if (__lock_release(lock, 0, ip))
 		check_chain_key(current);
 	current->lockdep_recursion = 0;
 	raw_local_irq_restore(flags);
