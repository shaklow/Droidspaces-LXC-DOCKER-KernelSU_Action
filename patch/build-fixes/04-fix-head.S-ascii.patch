From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: kernel-builder <builder@github.com>
Date: Mon, 9 Jun 2026 00:00:00 +0000
Subject: [PATCH] fix: remove unsupported \x escape in head.S for old Clang

Old Clang assembler does not support \x hex escapes in .ascii directive.

Signed-off-by: kernel-builder <builder@github.com>
---
 arch/arm64/kernel/head.S | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

@@ -92,7 +92,7 @@
 	.quad	0				// reserved
 	.quad	0				// reserved
 	.quad	0				// reserved
-	.ascii	"ARM\x64"			// Magic number
+	.ascii	"ARMd"			// Magic number
 #ifdef CONFIG_EFI
 	.long	pe_header - _head		// Offset to the PE header.
 
