#内核源码地址
KERNEL_SOURCE=https://github.com/LineageOS/android_kernel_xiaomi_sm8250
#内核源码分支
KERNEL_SOURCE_BRANCH=lineage-23.2
#内核编译配置
KERNEL_CONFIG=vendor/kona_defconfig
#内核Image.gz-dtb or Image
KERNEL_IMAGE_NAME=Image
ARCH=arm64
#参数
EXTRA_CMDS:LD=ld.lld HOSTCC=gcc KCFLAGS=-Wno-unknown-warning-option -Wno-incompatible-pointer-types
EXTRA_CMDT:LLVM=1
EXTRA_CMDU:LLVM_IAS=1

########################################################################################################################################################
# 编译方案'A'clang+gcc编译 'B'clang编译
METHOD_OK=A



# 编译器选择'true'将使用自定义编译器Clang  'false'将使用编译器AOSP
USE_CUSTOM_CLANG=true

# python切换默认python3(ture将切换到python2)
CUT_PYTHON=false

# 自定义编译器Clang
## Custom
CUSTOM_CLANG_SOURCE=https://github.com/ravindu644/Android-Kernel-Tutorials/releases/download/toolchains/clang-r353983c.tar.gz
CUSTOM_CLANG_BRANCH=master

###如果您设置使用自定义clang为false，则不要更改自定义CMDS 
CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-

## 编译器AOSP
分支main     android-gs-bluejay-5.10-android13      android-msm-bonito-4.9-android12-qpr1  android-msm-coral-4.14-android13  
3289846       3289846                                3289846                                 3289846
r450784e      r416183b                               r383902                                 r383902
r475365b      r450784d                               r399163b                                r399163b
r487747c      r450784e                               r416183b                                r416183b
r498229
#分支
CLANG_BRANCH=android-msm-coral-4.14-android13
#版本
CLANG_VERSION=r353983c


########################################################################################################################################################

# 开启 LXC and DOCKER (见文末 Action 选项区块)
#LXC_DOCKER=true

# 是否打入LXC补丁 (DroidSpaces补丁已包含相同修复)
LXC_PATCH=false

# 关闭CONFIG_ANDROID_PARANOID_NETWORK配置防止docker and lxc出现网络问题
ANDROID_PARANOID_NETWORK_OFF=true

#######################################################################################################################################################

# 开启 KernelSU flags (见文末 Action 选项区块)
#ENABLE_KERNELSU=true
KERNELSU_TAG=v0.9.5

# 额外配置 Configuration
DISABLE-LTO=false
DISABLE_CC_WERROR=true
ADD_KPROBES_CONFIG=true
ADD_OVERLAYFS_CONFIG=true

# DroidSpaces 补丁 (xt_qtaguid + cgroup prefix) (见文末 Action 选项区块)
#DROIDSPACES_PATCH=true
# DroidSpaces 内核配置 (namespaces/cgroups/seccomp/overlayfs/网络隔离等) (见文末 Action 选项区块)
#DROIDSPACES_CONFIG=true
# DroidSpaces 额外配置 (UFW/Fail2Ban/IPSET) (见文末 Action 选项区块)
#DROIDSPACES_ADDITIONAL_CONFIG=true

########################################################################################################################################################
# 开启 KVM 配置 (见文末 Action 选项区块)
#ENABLE_KVM=true


########################################################################################################################################################

# 开启缓存Ccache
ENABLE_CCACHE=true


# DTBO image
NEED_DTBO=false

# 构建内核直链接Build boot images
BUILD_BOOT_IMG=true
SOURCE_BOOT_IMAGE=https://pan.tenire.com/down.php/bc4fac7e1dd6dc44c4764e9bfdbc3dd5.img

########################################################################################################################################################
#                    Action 运行时可选配置（config.env 优先级高于 Action 界面选项）                                                                      #
#  用法：取消注释（删除行首 #）即启用，注释（添加行首 #）则回退到 Action 界面选项                                                                     #
#  测试时取消注释即可覆盖 Action 界面设置                                                                                                               #
########################################################################################################################################################

# 启用 KernelSU
#ENABLE_KERNELSU=true

# 开启 LXC and DOCKER 支持
#LXC_DOCKER=true

# 开启 KVM 虚拟化
#ENABLE_KVM=true

# 打入 DroidSpaces 补丁
#DROIDSPACES_PATCH=true

# 应用 DroidSpaces 内核配置
#DROIDSPACES_CONFIG=true

# 应用 DroidSpaces 额外配置 (UFW/Fail2Ban/IPSET)
#DROIDSPACES_ADDITIONAL_CONFIG=true
